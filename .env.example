# ============================================================
# Polymarket 单钱包凭证 (用于非 poly-multi 模式)
# ============================================================
POLYMARKET_TRADER_PRIVATE_KEY=
POLYMARKET_PROXY_ADDRESS=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=

# ============================================================
# Poly-Multi 钱包加密主密码
# 用于 AES-256-GCM 加密/解密 SQLite 中存储的钱包私钥
# 留空则使用内置默认值
# ============================================================
# POLY_MULTI_MASTER_PASSWORD=

# ============================================================
# Telegram 通知 (可选)
# ============================================================
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# POLY_MULTI_TELEGRAM_BOT_TOKEN=
# POLY_MULTI_TELEGRAM_CHAT_ID=

# ============================================================
# 服务配置
# ============================================================
POLY_MULTI_PORT=3020
POLY_MULTI_HOST=0.0.0.0
POLY_MULTI_DATA_DIR=./data

# ============================================================
# SSH 部署 (setup-polymarket-env.py 使用, 可选)
# ============================================================
# POLY_SSH_HOST=
# POLY_SSH_ENV_PATH=
# POLY_SSH_PM2_APP=
